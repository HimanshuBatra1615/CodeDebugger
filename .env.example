# Copy this file to .env inside the backend/ directory
# and fill in your values before starting the server.

# Google Gemini API key (required for live AI analysis)
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Gemini model to use
# gemini-1.5-flash  → free tier (15 RPM, 1M tokens/day) ← recommended
# gemini-1.5-pro    → higher quality, lower free quota
# gemini-2.0-flash  → fastest, very generous free tier
MODEL=gemini-1.5-flash

# Maximum number of AI suggestions to generate per analysis
MAX_SUGGESTIONS=10
